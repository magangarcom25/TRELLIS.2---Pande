{
    "model": {
        "resolution": 32,
        "in_channels": 8,
        "model_channels": 128,
        "out_channels": 8,
        "num_res_blocks": 12
    },
    "dataset": {
        "name": "ImageConditionedSLat",
        "args": {
            "roots": "./datasets/Ganesha_Dataset",
            "resolution": 64
        }
    },
    "trainer": {
        "name": "ImageConditionedSparseFlowMatchingCFGTrainer",
        "args": {
            "use_cfg": false,
            "max_steps": 500,
            "batch_size": 1,
            "accumulate_grad_batches": 32, 
            "fp16_mode": "bf16",
            "gradient_checkpointing": true,
            "save_every": 100,
            "optimizer": {
                "name": "DeepSpeedCPUAdam",
                "args": { 
                    "lr": 4e-5,
                    "offload_optimizer_states": true,
                    "offload_params": false
                } 
            }
        }
    }
}